@startuml messagedefinition-er-diagram
' ============================================================================
' DIAGRAM 1: Entity-Relationship Diagram - Message Definition as Hub
' ============================================================================
' Shows messagedefinition as the central hub with all its relationships
' Best for: Understanding table structure and foreign key relationships

!define PK <b><color:red>PK</color></b>
!define FK <color:blue>FK</color>
!define NOT_NULL <color:green>●</color>

skinparam linetype ortho
skinparam packageStyle rectangle

entity "messagedefinition" as msg <<Hub Table - 32 rows>> #LightYellow {
  PK id : numeric
  --
  NOT_NULL messagekey : varchar(50) <<unique>>
  NOT_NULL namespace : varchar
  soapaction : varchar
  elementvalue : varchar
  filterxpath : varchar
  NOT_NULL validationactive : boolean
  configurationname : varchar
  description : varchar
  NOT_NULL factorysetting : boolean
  changecounter : numeric
}

entity "elementdefinition" as elem {
  PK id : numeric
  --
  FK messagedefinition_id
  FK parent_id (self)
  name : varchar
  xpath : varchar
}

entity "transformationdefinition" as trans {
  PK id : numeric
  --
  FK messagedefinitionoriginal_id
  FK messagedefinitiontarget_id
  FK content_id
}

entity "xsltcontent" as xslt {
  PK id : numeric
  --
  content : text
  description : varchar
}

entity "channeldefinition" as channel {
  PK id : numeric
  --
  FK servicedefinition_id
  FK filtermessagedefinition_id
  FK adapterendpoint_id
  FK requesttransformation_id
  FK responsetransformation_id
  filterxpath : varchar(4000)
  active : boolean
}

entity "servicecomponentrelation" as scr {
  PK id : numeric
  --
  FK servicedefinition_id
  FK adapterdefinition_id
  FK messagedefinitionrequest_id
  FK messagedefinitionresponse_id
  FK messagedefinitionfault_id
}

entity "servicedefinition" as svc <<220 rows>> #LightBlue {
  PK id : numeric
  --
  name : varchar(50)
  handling : varchar (SYN/ASYN)
  status : varchar
  validation : boolean
}

entity "logmessage" as log {
  PK id : numeric
  --
  messagekey : varchar
  namespace : varchar
  message : text <<SOAP/XML>>
  elementvalue : varchar
}

' Relationships with cardinality
msg ||--o{ elem : "contains\nelements"
msg ||--o{ trans : "source format"
msg ||--o{ trans : "target format"
trans }o--|| xslt : "uses XSLT"
msg ||--o{ channel : "filter by"
msg ||--o{ scr : "request\nmessage"
msg ||--o{ scr : "response\nmessage"
msg ||--o{ scr : "fault\nmessage"
scr }o--|| svc : "defines"
channel }o--|| svc : "routes to"
msg ||..o{ log : "logged as\n(messagekey,\nnamespace)"

