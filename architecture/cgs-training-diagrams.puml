' ─── THE CORE: CGS ───
package "CGS — Municipal Service Bus" as cgs_core <<Enterprise Service Bus>> #E3F2FD {
  
  component "**STEP 1**\nConfig Validation\n//Is this a valid service call?//" as step1 #BBDEFB
  component "**STEP 2**\nAuthorization\n//Is this app allowed?//" as step2 #BBDEFB
  component "**STEP 3**\nMessage Matching\n//What message format is this?//" as step3 #BBDEFB
  component "**STEP 4**\nValidation\n//Is the message correct?//" as step4 #BBDEFB
  component "**STEP 5**\nRouting\n//Where should it go?//" as step5 #90CAF9
  component "**STEP 6**\nTransformation\n//Convert format if needed//" as step6 #90CAF9
  component "**STEP 7**\nDelivery\n//Send to provider(s)//" as step7 #90CAF9
  
  component "Async Queue\n//Store & forward\nfor async services//" as queue #FFF9C4
  
  component "Logging &\nMonitoring\n//Dashboard, audit trail//" as logging #E1BEE7
  
  step1 -right-> step2
  step2 -right-> step3
  step3 -right-> step4
  step4 -down-> step5
  step5 -left-> step6
  step6 -left-> step7
  step5 .down.> queue : async only
  queue .left.> step7 : when app is open
  
  step1 ..> logging
  step5 ..> logging
  step7 ..> logging
}

