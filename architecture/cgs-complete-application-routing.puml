@startuml cgs-request-to-response-flow
' ╔══════════════════════════════════════════════════════════════════════════╗
' ║  CGS LOGICAL REQUEST → RESPONSE FLOW                                   ║
' ║  Complete message lifecycle with all message types at each step         ║
' ║  Shows both SYNC and ASYNC paths                                       ║
' ╚══════════════════════════════════════════════════════════════════════════╝

title **CGS Request → Response: Complete Message Lifecycle**\n//Every message type used at each processing step//\n<size:10>2065 message definitions · 993 transformations · 10 adapter protocols</size>

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 10

|#E8F5E9| Consumer Application |

start
:Consumer sends **Request Message**
to CGS service endpoint;

note right
  **Request message types (from DB):**
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  • vraagBericht (471× StUF BG 0204)
  • kennisgevingsBericht (354× StUF BG 0204)
  • asynchroonAntwoordBericht (228×)
  • GenereerDistribueerNr (BV-BSN)
  • ActualiserenGBA (CPE)
  • PRLGOnDemandCreate* (ITP)
  • AiaAuthoring* (ITP)
  • BevragingBRP (BRP)
  • BijhoudingBRP (BRP)
  • CMIS* requests (DMS)
  • GSD*/DUO*/UWV* (Social domain)
  • KVKEvent/NHR* (Companies)
  • Digikoppeling* (Government)
  • Berichtenbox* (MijnOverheid)
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  **Protocols IN:**
  WEBSERVICE (45 in-adapters)
  ABAP (4), JAVA (4), HTTP (2)
  ebMS (1), REST (1), FILE (1)
end note

|#E3F2FD| CGS Service Bus |

partition "**PHASE 1: Authorization Check**" {
  :Lookup `serviceusage` table
  (660 authorization records)
  
  Does consumer X have access to service Y?;
  
  if (Authorized?) then (yes ✓)
  else (no ✗)
    :Return **Fault Message**;
    note right
      **Fo03Bericht** (StUF 0301)
      Used 2431× as fault!
      
      or **Foutbericht** (CGS internal)
      Used 1403× as fault
    end note
    |#E8F5E9| Consumer Application |
    stop
  endif
}

|#E3F2FD| CGS Service Bus |

partition "**PHASE 2: Service Resolution**" {
  :Find service in `servicedefinition`
  (220 active services)
  
  Determine handling mode:
  • **SYN** (184 services) — synchronous
  • **ASYN** (34 services) — asynchronous;
  
  :Log to `logservicerequest`
  consumer + service + timestamp;
}

partition "**PHASE 3: Message Matching**" {
  :Match incoming XML against
  `messagedefinition` (2065 types)
  
  Strategy (ordered):
  1. SOAPAction header
  2. Namespace + messagekey
  3. XPath filter (filterpath)
  4. Element value (elementvalue);
  
  note right
    **Matching determines:**
    • Which SCR to use
    • Which transformation needed
    • Which response format expected
    • Which fault format to return
    
    **Service Component Relation**
    (5852 wiring records)
    Links: service + adapter +
    request_msg + response_msg + fault_msg
  end note
}

partition "**PHASE 4: Request Transformation**" {
  if (Transformation needed?) then (yes)
    :Apply XSLT from `transformationdefinition`
    (993 rules, stored in `xsltcontent`)
    
    **Common transformations:**
    • StUF BG 0204 → BG 0210 (113 rules)
    • StUF BG 0204 → BG 0310 (102 rules)
    • StUF BG 0210 → BG 0310
    • StUF 0204 → 0301 framework
    • Any custom wildCardRequest;
    
    :Log transformed message
    to `logaction` (3236 entries);
  else (no)
  endif
}

partition "**PHASE 5: Dynamic Routing**" {
  :Evaluate `channeldefinition`
  (532 active channels)
  
  Filter criteria (AND logic):
  • filterprovidingapplication_id
  • filtermessagedefinition_id
  • XPath content filter
  • Organisation filter
  • Channel active = true;
  
  note right
    **Fan-out examples (from DB):**
    ━━━━━━━━━━━━━━━━━━━━━━━━━
    StUFOntvangAsynchroonBG:
      29 channels → 17 providers
    StUFOntvangAsynchroonZKN:
      18 channels → 13 providers
    BerichtenboxBerichtverwerkservice:
      8 channels → 6 providers
    StUFOntvangAsynchroonWOZ:
      6 channels → 6 providers
    StUFOntvangAsynchroonEF:
      6 channels → 6 providers
    CMISObjectService:
      4 channels → 4 DMS providers
  end note
}

if (Service handling?) then (SYN — Synchronous)

  |#FFF3E0| Synchronous Path (184 services) |
  
  partition "**PHASE 6A: Synchronous Delivery**" {
    :Send to provider via adapter
    (single channel, wait for response);
    
    note right
      **Protocols OUT:**
      WEBSERVICE (54 out-adapters)
      JAVA (19), HTTP (8)
      ABAP (2), FTP (2), MQ (2)
      UNIFACE (3), ebMS (1)
      
      **Endpoint resolution:**
      adapterdefinition → adapterendpoint
      → endpointconfiguration (491 configs)
      URL + credentials + TLS cert
    end note
  }
  
  :Provider processes request
  and returns **Response Message**;
  
  note right
    **Response message types:**
    ━━━━━━━━━━━━━━━━━━━━━━━━━
    • synchroonAntwoordBericht (258×)
    • GenereerDistribueerNrResponse
    • ActualiserenGBAAntwoord
    • PRLGOnDemandCreate*Response
    • BevragingBRPResponse
    • CMIS* responses
    • GSD*/DUO*/UWV* responses
    • StUFBeantwoordVraag*Response
  end note
  
  partition "**PHASE 7A: Response Transformation**" {
    if (Response transformation?) then (yes)
      :Apply response XSLT
      (responsetransformation_id in SCR)
      
      **Key pattern: Bv04 → Bv03**
      Provider returns Bv04Bericht (1570×)
      CGS transforms to Bv03Bericht (893×)
      for apps that expect Bv03;
    else (no)
    endif
  }
  
  |#E8F5E9| Consumer Application |
  
  :Consumer receives
  **Response** or **Fault**;
  
  note right
    **Final response types:**
    • synchroonAntwoordBericht (success)
    • bevestigingsBericht StUF 0204 (925×)
    • bevestigingsBericht StUF 0210 (387×)
    • Bv03Bericht StUF 0301 (893×)
    • Fo03Bericht (fault, 2431×)
    • Fo02Bericht (fault, 588×)
    • foutBericht StUF 0204 (575×)
    • Foutbericht CGS (1403×)
  end note
  
  stop

else (ASYN — Asynchronous)

  |#FCE4EC| Asynchronous Path (34 services) |
  
  partition "**PHASE 6B: Immediate Confirmation**" {
    :Return **Bv04Bericht** to consumer
    (broker confirmation = "message received")
    Used 1570× as response;
  }
  
  |#E8F5E9| Consumer Application |
  :Consumer receives Bv04Bericht
  (or Bv03 after transformation);
  
  |#FCE4EC| Asynchronous Path (34 services) |
  
  partition "**PHASE 7B: Queue & Fan-out**" {
    :For EACH matched channel:
    Place copy in sending queue
    (QoS = EXACTLYONCE);
    
    :Check `applicationopeningperiod`
    Is target app currently open?;
    
    if (App open?) then (yes)
      :Deliver immediately;
    else (no — closed)
      :Hold in queue until
      opening period starts;
      :...(time passes)...
      App opens → deliver;
    endif
  }
  
  |#FFF9C4| Per Provider Channel (repeated) |
  
  partition "**PHASE 8B: Channel Delivery**" {
    :Apply channel-specific transformation
    (if requesttransformation_id set)
    
    Send to provider endpoint
    via configured adapter protocol;
    
    note right
      **Example: StUFOntvangAsynchroonBG**
      delivers to ALL of these:
      ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
      4WOZ → ABAP adapter
      CBB → ABAP adapter
      CBR → ABAP adapter
      CGA → ABAP adapter
      CGS → Java internal
      CIN → ABAP adapter
      CKD → ABAP adapter
      CMD → ABAP adapter
      CMG → Java adapter
      CMM → Java adapter
      CMO → Java adapter
      CWIZ → UNIFACE adapter
      CZA → ABAP adapter
      GEOTAX → WEBSERVICE
      Legacy → Java adapter
      TOG → WEBSERVICE
      WebNext → HTTP adapter
    end note
