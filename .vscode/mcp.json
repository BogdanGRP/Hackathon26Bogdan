{
    "servers": {
        "archimate": {
            "command": "npx",
            "args": [
                "-y",
                "archimate-mcp-server@latest"
            ],
            "type": "stdio"
        },
        "igp-ontwikkel-readonly": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-postgres",
                "postgresql://hackathon:hackathon@localhost:5432/igp_ontwikkel"
            ],
            "env": {
                "DEBUG": "false"
            },
            "type": "stdio"
        }
    },
    "inputs": []
}
